# VP Ride API + admin — used when the web server’s document root is this /public folder.
# Production (vpride.ca): if the site serves the app only under https://vpride.ca/backend/ and maps
# that subpath to this folder, set RewriteBase to e.g. /backend/public/ . Local php -S from here: / .
#
# If the host uses the parent folder’s backend/.htaccess instead, this file may not apply to every request.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Front controller: real files (CSS, etc.) pass through; everything else → index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [QSA,L]
</IfModule>
