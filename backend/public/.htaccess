# VP Ride API + admin — document root should be this /public folder.
# Live URL: https://www.webspace.ng/vpride/backend/public/
#
# If you change folder names, update RewriteBase to match (leading + trailing slash).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /vpride/backend/public/

  # Front controller: real files (CSS, etc.) pass through; everything else → index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [QSA,L]
</IfModule>
