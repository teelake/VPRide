# Use this ONLY if your hosting URL includes /public/ (e.g. …/vpride/backend/public/).
# Recommended setup: use backend/.htaccess + backend/index.php so the URL is …/vpride/backend/ (no /public).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /vpride/backend/public/

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.php [L]
</IfModule>
