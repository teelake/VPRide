# Copy to .env and adjust. Never commit .env.

# PHP errors → backend/storage/logs/php-error.log (ensure storage/logs is writable).
# PHP_ERROR_LOG_DISABLE=1
# PHP_ERROR_LOG_FILE=C:/path/to/custom-error.log

# Subfolder URL path to THIS backend (no trailing slash, no /public).
# Production (vpride.ca): admin + API are at https://vpride.ca/backend/  →  APP_BASE_PATH=backend
# Local `php -S` from public: leave empty.
APP_BASE_PATH=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpride
DB_USERNAME=root
DB_PASSWORD=

# Public site URL for links and uploaded assets (no trailing slash).
# Production: same path as the backend (e.g. https://vpride.ca/backend) with APP_BASE_PATH=backend.
# Local dev: http://localhost:8080 is fine with APP_BASE_PATH= empty. If unset, request host + APP_BASE_PATH is used.
PUBLIC_BASE_URL=http://localhost:8080

# From: header fallback when Admin → Settings → Email → From is empty (required for deliverability on most hosts)
# APP_MAIL_FROM=VP Ride <noreply@yourdomain.com>

# Fallback staff addresses when the database list is empty (prefer configuring Email tab in Admin → Settings)
# RIDER_SIGNUP_NOTIFY_EMAIL=ops@yourdomain.com

# Rider welcome and staff signup mail are configured in Admin → Settings → Email (defaults: both enabled).

# Google Sign-In server client ID — ID token audience / Flutter GOOGLE_SERVER_CLIENT_ID (OAuth type "Web application" in Cloud Console; not a website). Required for POST /api/v1/auth/google.
GOOGLE_OAUTH_CLIENT_ID=

# Optional: Maps/Geocoding key for mobile via GET /api/v1/config/public when the admin "Maps API key" field is empty.
# Prefer saving the key in Admin → Settings (stored in DB); this env is a fallback for the same value.
# MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

# CORS: * for dev; production use your Flutter web origin or comma-separated allow list
API_CORS_ORIGIN=*

# Max POST /api/v1/auth/google calls per IP per hour (default 60)
# API_RATE_LIMIT_AUTH_PER_HOUR=60

# Max POST /api/v1/log/client (mobile error reports) per IP per hour (default 180)
# API_RATE_LIMIT_CLIENT_LOG_PER_HOUR=180

# Optional overrides for scripts/seed.php
# SEED_ADMIN_EMAIL=admin@vpride.local
# SEED_ADMIN_DISPLAY_NAME=System administrator
# SEED_ADMIN_PASSWORD=Admin@123
