# Copy to .env and adjust. Never commit .env.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpride
DB_USERNAME=root
DB_PASSWORD=

# Shown on admin dashboard for the public API link (no trailing slash)
PUBLIC_BASE_URL=http://localhost:8080

