# Copy to .env and adjust. Never commit .env.

# If the site is in a subfolder (not domain root), set the web path to the folder that contains index.php.
# Example: https://www.webspace.ng/vpride/backend/public/ →  APP_BASE_PATH=vpride/backend/public
# Leave empty when the app is at the domain root.
APP_BASE_PATH=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpride
DB_USERNAME=root
DB_PASSWORD=

# Full public URL to this app (no trailing slash), e.g. https://www.webspace.ng/vpride/backend/public
PUBLIC_BASE_URL=http://localhost:8080

# Optional overrides for scripts/seed.php
# SEED_ADMIN_EMAIL=admin@vpride.local
# SEED_ADMIN_PASSWORD=Admin@123
