# Copy to .env and adjust. Never commit .env.

# Subfolder URL path to THIS backend (no trailing slash, no /public).
# Example URL: https://webspace.ng/vpride/backend/admin/login  →  APP_BASE_PATH=vpride/backend
# Leave empty when the app is at the domain root.
APP_BASE_PATH=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpride
DB_USERNAME=root
DB_PASSWORD=

# Full public URL to this backend (no trailing slash), e.g. https://webspace.ng/vpride/backend
PUBLIC_BASE_URL=http://localhost:8080

# Google OAuth Web client ID (same as Flutter GOOGLE_SERVER_CLIENT_ID). Required for POST /api/v1/auth/google.
GOOGLE_OAUTH_CLIENT_ID=

# CORS: * for dev; production use your Flutter web origin or comma-separated allow list
API_CORS_ORIGIN=*

# Max POST /api/v1/auth/google calls per IP per hour (default 60)
# API_RATE_LIMIT_AUTH_PER_HOUR=60

# Optional overrides for scripts/seed.php
# SEED_ADMIN_EMAIL=admin@vpride.local
# SEED_ADMIN_PASSWORD=Admin@123
