# Optional: only used if someone opens …/vpride/backend/ (without /public).
# Primary setup: point the site at /vpride/backend/public/ and use public/.htaccess.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /vpride/backend/

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ public/index.php [QSA,L]
</IfModule>
