# Place this file in the "backend" folder next to index.php (same level as /public).
# URL example: https://webspace.ng/vpride/backend/admin/login
#
# 1) Edit RewriteBase to match your folder path (leading + trailing slash).
# 2) In .env set APP_BASE_PATH to the SAME path WITHOUT trailing slash and WITHOUT "public"
#    Example: APP_BASE_PATH=vpride/backend

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /vpride/backend/

  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.php [L]
</IfModule>

# If mod_rewrite is off, enable it in hosting panel or ask support.
